# Copia este archivo como .env y rellena los valores reales

# URL de tu GitHub Pages (para permitir CORS)
# Formato: https://TU_USUARIO.github.io/TU_REPO
GITHUB_PAGES_URL=https://TU_USUARIO.github.io/TU_REPO

# Correo destino (quien recibe las solicitudes de cita)
CONTACT_EMAIL=tu_correo@gmail.com

# Cuenta Gmail desde la que se envía el email
# Genera una contraseña de aplicación en:
# https://myaccount.google.com/apppasswords
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_contraseña_de_aplicacion

# Protección antispam
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW_MINUTES=60

